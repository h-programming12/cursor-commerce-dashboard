## 사용할 유틸 함수 (lib/ai/gemini.ts에 이미 구현되어 있음)

import { generateGeminiTextWithSystemPrompt } from "@/lib/ai/gemini";

함수 시그니처:
generateGeminiTextWithSystemPrompt(
systemPrompt: string,
userPrompt: string,
model?: string // 기본값: "gemini-2.5-flash"
): Promise<string>

